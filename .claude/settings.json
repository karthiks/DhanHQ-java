{
    "env": {
        "ANTHROPIC_MODEL":"openrouter/free",
        "ANTHROPIC_SMALL_FAST_MODEL":"openrouter/free",
        "ANTHROPIC_DEFAULT_SONNET_MODEL":"openrouter/free",
        "ANTHROPIC_DEFAULT_OPUS_MODEL":"openrouter/free",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL":"openrouter/free",
        "CLAUDE_CODE_DEFAULT_MODEL":"openrouter/free",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC":"1",
        "CLAUDE_CODE_ENABLE_CACHE": "true",
        "CLAUDE_CODE_CACHE_TTL": "300" // 5 minutes default
    },
    "permissions": {
        "filesystem": {
            "read": ["src/", "pom.xml", "README.md"],
            "write": ["src/", "pom.xml", "README.md"]
        },
        "shell": {
            "execute": ["mvn", "git"]
        },
        "git": {
            "enabled": true,
            "repositories": ["."],
            "allowed_commands": [
                "status", "diff", "add", "commit", "push", "pull",
                "checkout", "branch", "log", "merge", "rebase"
            ]
        }
    }
}
